{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "./build"
            ],
            "problemMatcher": [],
            "group": "none"
        },
        {
            "label": "CMake: Build Client",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./build",
                "--target",
                "client"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        },
        {
            "label": "CMake: Build Server",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./build",
                "--target",
                "server"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        },
        {
            "label": "CMake: Build All",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./build"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        }
    ]
}

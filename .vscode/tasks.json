{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "presentation": {
                "reveal": "silent"
            },
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "./out/build"
            ],
            "problemMatcher": [],
            "group": "none"
        },
        {
            "label": "CMake: Build (preset)",
            "presentation": {
                "reveal": "silent"
            },
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "${input:buildPreset}"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "dependsOn": [
                "CMake: Configure"
            ]
        },
        {
            "label": "CMake: Build Client (Debug)",
            "presentation": {
                "reveal": "silent"
            },
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "client-debug"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "dependsOn": [
                "CMake: Configure"
            ]
        },
        {
            "label": "CMake: Build Client (Release)",
            "presentation": {
                "reveal": "silent"
            },
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "client-release"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "dependsOn": [
                "CMake: Configure"
            ]
        },
        {
            "label": "CMake: Build Server (Debug)",
            "presentation": {
                "reveal": "silent"
            },
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "server-debug"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "dependsOn": [
                "CMake: Configure"
            ]
        },
        {
            "label": "CMake: Build Server (Release)",
            "presentation": {
                "reveal": "silent"
            },
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "server-release"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "dependsOn": [
                "CMake: Configure"
            ]
        },
    ],
    "inputs": [
        {
            "id": "buildPreset",
            "type": "pickString",
            "options": [
                "client-debug",
                "client-release",
                "server-debug",
                "server-release",
                "client-asan",
                "server-asan"
            ],
            "default": "client-debug"
        }
    ]
}
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "./out/build"
            ],
            "problemMatcher": [],
            "group": "none"
        },
        {
            "label": "CMake: Build Client (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./out/build",
                "--target",
                "client",
                "--config",
                "Debug"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        },
        {
            "label": "CMake: Build Client (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./out/build",
                "--target",
                "client",
                "--config",
                "Release"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        },
        {
            "label": "CMake: Build Server (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./out/build",
                "--target",
                "server",
                "--config",
                "Debug"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        },
        {
            "label": "CMake: Build Server (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./out/build",
                "--target",
                "server",
                "--config",
                "Release"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        },
        {
            "label": "CMake: Build All (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./out/build",
                "--config",
                "Debug"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        },
        {
            "label": "CMake: Build All (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "./out/build",
                "--config",
                "Release"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build",
            "dependsOn": ["CMake: Configure"]
        }
    ]
}

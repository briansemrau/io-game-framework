{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build: Linux Server (Release)",
			"type": "shell",
			"command": "bash",
			"args": ["./scripts/build/build-linux-server.sh", "release"],
			"problemMatcher": ["$gcc"],
			"group": "build"
		},
		{
			"label": "Build: Linux Server (Debug)",
			"type": "shell",
			"command": "bash",
			"args": ["./scripts/build/build-linux-server.sh", "debug"],
			"problemMatcher": ["$gcc"],
			"group": "build"
		},
		{
			"label": "Build: Linux Client (Release)",
			"type": "shell",
			"command": "bash",
			"args": ["./scripts/build/build-linux-client.sh", "release"],
			"problemMatcher": ["$gcc"],
			"group": "build"
		},
		{
			"label": "Build: Linux Client (Debug)",
			"type": "shell",
			"command": "bash",
			"args": ["./scripts/build/build-linux-client.sh", "debug"],
			"problemMatcher": ["$gcc"],
			"group": "build"
		},
		{
			"label": "Build: WASM Client (Release)",
			"type": "shell",
			"command": "bash",
			"args": ["./scripts/build/build-wasm-client.sh", "release"],
			"problemMatcher": ["$gcc"],
			"group": "build"
		},
		{
			"label": "Build: WASM Client (Debug)",
			"type": "shell",
			"command": "bash",
			"args": ["./scripts/build/build-wasm-client.sh", "debug"],
			"problemMatcher": ["$gcc"],
			"group": "build"
		},
		{
			"label": "Build: Windows MSVC Client (Release)",
			"type": "shell",
			"command": "powershell",
			"args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "./scripts/build/build-windows-msvc-client.ps1", "release"],
			"problemMatcher": ["$msCompile"],
			"group": "build"
		},
		{
			"label": "Build: Windows MSVC Client (Debug)",
			"type": "shell",
			"command": "powershell",
			"args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "./scripts/build/build-windows-msvc-client.ps1", "debug"],
			"problemMatcher": ["$msCompile"],
			"group": "build"
		},
		{
			"label": "Build: Windows MSVC Server (Release)",
			"type": "shell",
			"command": "powershell",
			"args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "./scripts/build/build-windows-msvc-server.ps1", "release"],
			"problemMatcher": ["$msCompile"],
			"group": "build"
		},
		{
			"label": "Build: Windows MSVC Server (Debug)",
			"type": "shell",
			"command": "powershell",
			"args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "./scripts/build/build-windows-msvc-server.ps1", "debug"],
			"problemMatcher": ["$msCompile"],
			"group": "build"
		}
	]
}
